# Ollama configuration (local models)
OLLAMA_BASE_URL=http://localhost:11434
MODEL_NAME=ollama/llama3.2
MAX_TOKENS=4096

# MLX configuration (Apple Silicon Macs)
# Use "mlx/<huggingface-repo>" or "mlx/<local-path>" as MODEL_NAME, e.g.:
# MODEL_NAME=mlx/BeastCode/Qwen3.5-27B-Claude-4.6-Opus-Distilled-MLX-4bit
# Or set MLX_MODEL_PATH to a local directory containing the model weights:
# MLX_MODEL_PATH=/Users/you/models/Qwen3.5-27B-Claude-4.6-Opus-Distilled-MLX-4bit

# Optional: Cloud API keys (not needed for local Ollama/MLX)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...

# OpenRouter — 300+ models via one API key, many free with :free suffix
# Get your key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...
# Example models:
#   MODEL_NAME=openrouter/google/gemma-3-4b-it:free
#   MODEL_NAME=openrouter/meta-llama/llama-4-scout:free
#   MODEL_NAME=openrouter/qwen/qwen3-8b:free
#   MODEL_NAME=openrouter/deepseek/deepseek-r1-0528:free
#   MODEL_NAME=openrouter/anthropic/claude-sonnet-4-5
